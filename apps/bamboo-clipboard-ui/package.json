{
  "name": "pandaclip",
  "version": "1.0.3",
  "description": "Agent activity lens: live desktop feed of clipboard activity, plus optional knowledge-graph, notes, and git commit sources you point at your own stores.",
  "private": true,
  "author": "VektorGeist",
  "license": "Apache-2.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {},
  "build": {
    "appId": "com.pandamcp.bambooclipboard",
    "productName": "PandaClip",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "ui/**",
      "package.json"
    ],
    "asarUnpack": [
      "src/watcher.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "ui/assets/icon.ico"
    }
  }
}
