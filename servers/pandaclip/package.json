{
  "name": "@panda-mcp/pandaclip",
  "version": "1.0.4",
  "description": "PandaClip — one local-first MCP server: clipboard history & snippets, TTL cache, file-organizer overlay, and a knowledge graph. SQLite everywhere, no daemons, no network.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xfloukiex-lab/pandaclip.git",
    "directory": "servers/pandaclip"
  },
  "homepage": "https://github.com/xfloukiex-lab/pandaclip#readme",
  "bugs": "https://github.com/xfloukiex-lab/pandaclip/issues",
  "keywords": ["mcp", "model-context-protocol", "clipboard", "cache", "knowledge-graph", "sqlite", "local-first", "agent-tools"],
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pandaclip": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@panda-mcp/core": "0.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
