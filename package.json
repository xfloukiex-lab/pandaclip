{
  "name": "panda-mcp",
  "private": true,
  "version": "1.0.3",
  "license": "Apache-2.0",
  "description": "PandaClip — one local-first MCP server (clipboard, cache, file overlay, knowledge graph) + desktop activity lens",
  "type": "module",
  "workspaces": [
    "packages/*",
    "servers/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
